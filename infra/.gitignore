# Local .terraform directories
**/.terraform/*

# .tfstate files — state must be remote (GCS backend)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Lock file — commit to pin provider versions
# .terraform.lock.hcl

# macOS
.DS_Store
